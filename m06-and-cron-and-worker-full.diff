+      }),
+    }).catch(e => console.warn('[TradeRating] 온도 갱신 실패:', e.message));
+  }
+
+  return new Response(JSON.stringify({ ok: true, record_id: inserted?.id || null, delta }), { status: 200, headers: corsHeaders });
+}
