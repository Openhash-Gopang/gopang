+    const currentCount = rateeProfile.temp_rating_count ?? 0;
+    const nextTemp = Math.max(TEMP_MIN, Math.min(TEMP_MAX, currentTemp + delta));
+    await fetch(`${l1Base}/api/collections/profiles/records/${rateeProfile.id}`, {
