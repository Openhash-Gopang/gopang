+// GET /biz/trade-rating/list?ratee_guid=&lang=&viewer_lang=&limit=&offset=&l1_node=
+// 목록 + 언어별 편향 요약. l1_node 미지정 시 ratee 소속 L1로 조회(§ handleTradeRatingSubmit과 동일 기본값).
+async function handleTradeRatingList(request, env, corsHeaders) {
+  const url = new URL(request.url);
+  const ratee_guid = url.searchParams.get('ratee_guid');
+  const langFilter = url.searchParams.get('lang'); // 특정 언어권만 보기(선택)
+  const viewerLang = url.searchParams.get('viewer_lang') || 'ko';
+  const limit = Math.min(Number(url.searchParams.get('limit') || 20), 50);
+  const offset = Number(url.searchParams.get('offset') || 0);
+  if (!ratee_guid) return _err(400, 'MISSING_FIELD', 'ratee_guid 필수', corsHeaders);
+
+  const homeNodeId = url.searchParams.get('l1_node') || (await _resolveHomeL1Node(env, ratee_guid)) || 'KR-JEJU-JEJU-HANLIM';
+  const l1Base = L1_NODE_MAP[homeNodeId] || L1_DEFAULT;
+  const token = await _l1AdminTokenFor(env, l1Base);
+  const headers = { 'Authorization': `Bearer ${token}` };
+
+  // 요약은 전체(페이지네이션 무시)로 계산 — 목록만 lang 필터/페이지 적용
+  const allRes = await fetch(
+    `${l1Base}/api/collections/trade_ratings/records?filter=${encodeURIComponent(`ratee_guid='${ratee_guid}'`)}&perPage=500&sort=-created_at`,
+    { headers }
+  );
+  if (!allRes.ok) return _err(502, 'L1_UNREACHABLE', 'trade_ratings 조회 실패: ' + allRes.status, corsHeaders);
+  const allData = await allRes.json().catch(() => ({ items: [] }));
+  const allItems = allData.items || [];
+  const summary = _buildRatingSummaryByLang(allItems, viewerLang);
+
+  const filtered = langFilter ? allItems.filter(r => (r.rater_lang || 'ko') === langFilter) : allItems;
+  const page = filtered.slice(offset, offset + limit).map(r => ({
+    rater_guid: r.rater_guid, polarity: r.polarity,
+    comment: r.comment, comment_translated: r.comment_translated, comment_lang: r.comment_lang,
+    rater_lang: r.rater_lang, amount: r.amount, category: r.category, created_at: r.created_at,
+  }));
+
+  return new Response(JSON.stringify({
+    ok: true, items: page, rating_summary: summary,
+    filter_lang: langFilter || null, pagination: { limit, offset },
+  }), { status: 200, headers: corsHeaders });
+}
