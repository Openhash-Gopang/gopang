+// Kakao 로컬 API(coord2regioncode)로 좌표→행정동명 역지오코딩 후 노드ID 조회.
+// env.KAKAO_REST_API_KEY 시크릿 필요(wrangler secret put KAKAO_REST_API_KEY).
+// 실패(키 미설정/API 오류/제주 밖 좌표 등)하면 null 반환 — 호출부가 hanlim으로 폴백.
+async function _resolveNodeIdFromGPS(env, lat, lng) {
+  if (typeof lat !== 'number' || typeof lng !== 'number') return null;
+  if (!env.KAKAO_REST_API_KEY) {
+    console.warn('[EMD] KAKAO_REST_API_KEY 미설정 — GPS 기반 L1 배정 불가, hanlim 폴백');
+    return null;
+  }
+  try {
+    const res = await fetch(
+      `https://dapi.kakao.com/v2/local/geo/coord2regioncode.json?x=${lng}&y=${lat}`,
+      { headers: { Authorization: `KakaoAK ${env.KAKAO_REST_API_KEY}` } }
+    );
+    if (!res.ok) {
+      console.warn('[EMD] Kakao 역지오코딩 실패:', res.status);
+      return null;
+    }
+    const data = await res.json().catch(() => null);
+    // region_type 'H'(행정동) 우선 — EMD_NAME_TO_NODE_ID가 행정동/읍면 이름 기준
+    const doc = data?.documents?.find(d => d.region_type === 'H') || data?.documents?.[0];
+    if (!doc) return null;
+    if (doc.region_2depth_name !== '제주시' && doc.region_2depth_name !== '서귀포시') {
+      console.warn('[EMD] 제주 밖 좌표 — GPS 기반 L1 배정 불가:', doc.region_2depth_name);
+      return null;
+    }
+    const nodeId = EMD_NAME_TO_NODE_ID[doc.region_3depth_name];
+    if (!nodeId) {
+      console.warn('[EMD] 매핑 테이블에 없는 읍면동명:', doc.region_3depth_name);
+      return null;
+    }
+    return nodeId;
+  } catch (e) {
+    console.warn('[EMD] GPS 해석 실패:', e.message);
+    return null;
+  }
+}
