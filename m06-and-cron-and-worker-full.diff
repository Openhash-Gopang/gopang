+async function _refreshCategoryMedians(env) {
+  for (const nodeId of L1_ONLY_NODE_IDS) {
+    const base = L1_NODE_MAP[nodeId];
+    if (!base) continue;
+    let token;
+    try {
+      token = await _l1AdminTokenFor(env, base);
+    } catch (e) {
+      console.warn(`[CategoryMedian] ${nodeId} 인증 실패, 건너뜀:`, e.message);
+      continue;
+    }
+
+    // 자체 제한 — 최근 갱신이 20시간 이내면 스킵
+    try {
+      const checkRes = await fetch(
+        `${base}/api/collections/category_medians/records?perPage=1&sort=-computed_at`,
+        { headers: { 'Authorization': `Bearer ${token}` } }
+      );
+      const checkData = await checkRes.json().catch(() => ({ items: [] }));
+      const last = checkData.items?.[0]?.computed_at;
+      if (last && (Date.now() - new Date(last).getTime()) < CATEGORY_MEDIAN_REFRESH_INTERVAL_MS) {
+        continue;
+      }
+    } catch (e) { /* category_medians 컬렉션이 아직 없을 수도 있음 — 아래에서 어차피 실패하고 건너뜀 */ }
+
+    const since = new Date(Date.now() - 90 * 24 * 60 * 60 * 1000).toISOString();
+    const byCategory = {};
+    let page = 1;
+    while (true) {
+      const filter = encodeURIComponent(`created_at>='${since}'`);
+      let res;
+      try {
+        res = await fetch(
+          `${base}/api/collections/trade_ratings/records?filter=${filter}&perPage=200&page=${page}`,
+          { headers: { 'Authorization': `Bearer ${token}` } }
+        );
+      } catch (e) {
+        console.warn(`[CategoryMedian] ${nodeId} trade_ratings 조회 실패:`, e.message);
+        break;
+      }
+      if (!res.ok) break;
+      const data = await res.json().catch(() => ({ items: [] }));
+      const items = data.items || [];
+      for (const r of items) {
+        if (!r.category || typeof r.amount !== 'number') continue;
+        if (!byCategory[r.category]) byCategory[r.category] = [];
+        byCategory[r.category].push(r.amount);
+      }
+      if (items.length < 200) break;
