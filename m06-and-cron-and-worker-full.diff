+// ═══════════════════════════════════════════════════════════
+// 2026-07-07 신설 — M06(국적별 평점 편향 감지 + 자동번역) 재구현.
+// src/profile2.0/review.js(고아 코드, worker.js가 import한 적 없음)의
+// 로직을 trade_ratings 위로 이관. 원본은 1~5점 rating 기준이었지만
+// trade_ratings는 polarity(positive/neutral/negative) 3단계라 척도가
+// 다르다 — 그대로 못 옮기고 폴라리티를 -1~+1 점수로 환산해 같은 원리
+// (언어별 평균 vs 전체 평균 격차)로 재구현한다.
+// ═══════════════════════════════════════════════════════════
+const POLARITY_SCORE = { positive: 1, neutral: 0, negative: -1 };
+// 원본 BIAS_THRESHOLD=1.0은 1~5점(범위4) 척도 기준. -1~+1(범위2)로 축소했으니
+// 비례해서 절반(0.5)으로 낮춘다 — 같은 "상대적 격차"를 의미하게 하기 위함.
+const BIAS_THRESHOLD = 0.5;
+const BIAS_MESSAGES = {
+  ko: '국적별 평가에 차이가 있습니다. 다양한 시각을 함께 참고해 주세요.',
+  zh: '不同国籍的评价存在差异，请综合参考多方观点。',
+  en: 'Ratings vary by nationality. Please consider diverse perspectives.',
+  ja: '国籍別の評価に差があります。様々な視点を参考にしてください。',
+  vi: 'Đánh giá khác nhau theo quốc tịch. Vui lòng tham khảo nhiều góc nhìn.',
+  th: 'การประเมินแตกต่างกันตามสัญชาติ โปรดพิจารณาจากหลายมุมมอง',
+};
+const LANG_LABEL = {
+  ko: '한국인', zh: '中国旅行者', en: 'English speakers',
+  ja: '日本人旅行者', vi: 'Du khách Việt Nam', th: 'นักท่องเที่ยวไทย',
+};
+
+function _detectRatingBias(viewerAvg, overallAvg) {
+  if (viewerAvg === null || overallAvg === null) return false;
+  return Math.abs(viewerAvg - overallAvg) >= BIAS_THRESHOLD;
+}
+
+// DeepSeek 번역 (M05/구 review.js와 동일 패턴) — 실패하면 원문 그대로 반환.
+async function _translateText(text, fromLang, toLang, apiKey) {
+  if (!text || fromLang === toLang) return text;
+  if (!apiKey) return text; // 키 미설정 — 조용히 원문 유지(번역은 부가 기능이라 등록 자체를 막지 않음)
+  try {
+    const res = await fetch('https://api.deepseek.com/v1/chat/completions', {
+      method: 'POST',
+      headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${apiKey}` },
+      body: JSON.stringify({
+        model: 'deepseek-chat',
+        max_tokens: 512,
+        messages: [{ role: 'user', content: `Translate from ${fromLang} to ${toLang}. Return only the translation.\n\n${text}` }],
+      }),
+    });
+    const data = await res.json();
+    return data.choices?.[0]?.message?.content?.trim() || text;
+  } catch { return text; }
+}
+
+// trade_ratings 레코드 배열(한 ratee 기준) → 언어별 집계 + 편향 경고.
+// 온도(temp_score)와는 완전히 별개 지표다 — 온도는 금액가중·평가자신뢰도까지
+// 반영한 신뢰지표, 이건 "언어권별 만족도 체감 차이"를 보여주는 별도 관점.
+function _buildRatingSummaryByLang(items, viewerLang) {
+  if (!items.length) {
+    return { overall: { count: 0, avg: null }, by_lang: [], viewer_highlight: null, bias_warning: null };
+  }
+  const grouped = {};
+  for (const r of items) {
+    const lang = r.rater_lang || 'ko';
+    (grouped[lang] = grouped[lang] || []).push(POLARITY_SCORE[r.polarity] ?? 0);
+  }
+  const totalCount = items.length;
+  const overallAvg = Math.round((items.reduce((s, r) => s + (POLARITY_SCORE[r.polarity] ?? 0), 0) / totalCount) * 100) / 100;
+
+  const by_lang = Object.entries(grouped).map(([lang, scores]) => ({
+    lang, label: LANG_LABEL[lang] || lang,
+    count: scores.length,
+    avg: Math.round((scores.reduce((a, b) => a + b, 0) / scores.length) * 100) / 100,
+    positive: scores.filter(s => s === 1).length,
+    negative: scores.filter(s => s === -1).length,
+  }));
+
+  const highlight = by_lang.find(b => b.lang === viewerLang) || null;
+  const viewerAvg = highlight?.avg ?? null;
+  const hasBias = _detectRatingBias(viewerAvg, overallAvg);
+
+  return {
+    overall: { count: totalCount, avg: overallAvg },
+    by_lang,
+    viewer_highlight: highlight,
+    bias_warning: hasBias ? (BIAS_MESSAGES[viewerLang] || BIAS_MESSAGES.en) : null,
+  };
+}
