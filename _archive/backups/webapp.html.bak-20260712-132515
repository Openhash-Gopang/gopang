<script>
function gopangLogout() {
  if (!confirm('로그아웃 하시겠습니까?\n(아이디·설정이 초기화됩니다)')) return;
  localStorage.clear();
  sessionStorage.clear();
  const _wipeIDB = (indexedDB.databases?.() || Promise.resolve([]))
    .then(dbs => Promise.all(dbs.map(db => indexedDB.deleteDatabase(db.name))))
    .catch(() => {});
  const _wipeCache = caches.keys().then(keys => Promise.all(keys.map(k => caches.delete(k))));
  Promise.all([_wipeIDB, _wipeCache]).finally(() => location.reload());
}
function _isGuestUser() {
  try {
    const s = JSON.parse(localStorage.getItem('gopang_user_v4') || sessionStorage.getItem('gopang_user_v4') || 'null');
    return !s || s.isGuest === true || !s.handle;
  } catch { return true; }
}
function _settingsLogoutOrLogin() { gopangLogout(); }
function _updateLogoutBtn() {
  const btn = document.getElementById('btn-logout-or-login');
  if (!btn) return;
  if (_isGuestUser()) {
    btn.style.display = 'none';
  } else {
    btn.style.display = 'block';
    btn.textContent = '로그아웃';
    btn.style.borderColor = '#fca5a5';
    btn.style.color = '#dc2626';
  }
}
</script>
