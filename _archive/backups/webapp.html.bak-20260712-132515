<style>

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;height:100dvh;overflow:hidden;
  font-family:'Pretendard',-apple-system,'Helvetica Neue',sans-serif;
  font-size:15px;background:#fff;color:#111;-webkit-font-smoothing:antialiased;
  /* 안드로이드 Chrome의 엣지 스와이프 "뒤로가기/앞으로가기" 제스처 차단.
     이게 없으면 왼쪽 가장자리 스와이프가 페이지 자체를 이탈시켜
     구글/안드로이드 화면으로 빠져나가 버린다. */
  overscroll-behavior-x:none;overscroll-behavior-y:none;touch-action:pan-y}
:root{
  /* Google Maps 블루 계열 (#1A73E8) — 구글 맵스 동일 톤 */
  --green:#1A73E8;--green-lt:#EEF4FF;--green-dk:#1557B0;--green-bd:#93C4F9;
  --blue:#1A73E8;--blue-lt:#EEF4FF;--blue-dk:#1557B0;
  --border:#DADCE0;--txt2:#5F6368;--txt3:#9AA0A6;
  --chip-bg:#f9fafb;--chip-border:#e5e7eb;
  --safe-t:env(safe-area-inset-top,0px);
  --safe-b:env(safe-area-inset-bottom,0px);
  /* 레거시 호환 */
  --tint:#1A73E8;--tint-dim:rgba(26,115,232,.08);
  --bg:#fff;--bg-subtle:#f9fafb;--bg-input:#f3f4f6;
  --label:#111;--label-2:#6b7280;--label-3:#9ca3af;
  --sep:#e5e7eb;--sep-strong:#d1d5db;
  --green-color:#1A73E8;
  --font:'Pretendard',-apple-system,sans-serif;
  --r-md:12px;
}

/* 설치된 PWA(standalone) 모드 — 안드로이드 하단 내비게이션 바가
   env(safe-area-inset-bottom)을 0으로 잘못 보고하는 기기가 많다.
   --safe-b-measured는 JS(visualViewport)가 기기에서 직접 측정해 채우는
   값이고, 초기값 48px는 그 JS가 아직 못 돌았을 때를 위한 임시 안전망이다
   (3버튼 내비게이션 바 기준치).
   ※ 과거에는 이 48px를 안전망이 아니라 max() 안의 "하한선"으로
   CSS에 직접 박아뒀었다. 그래서 JS가 정상적으로 동작해 실제 값(제스처
   내비게이션 기기 등에서는 0에 가까움)을 측정해도 항상 48px 이상으로
   강제되어, 설치된 PWA에서 입력창이 화면 하단으로부터 불필요하게
   떠 보이는 버그가 있었다(특히 제스처 내비게이션 기기에서 두드러짐).
   지금은 48px를 --safe-b-measured의 "초기값"으로만 두고, measure()가
   실제 측정에 성공하면(0이라도) 그 값을 그대로 신뢰하도록 바꿨다. */
:root { --safe-b-measured: 48px; }
@media (display-mode: standalone) {
  :root {
    --safe-b: max(env(safe-area-inset-bottom, 0px), var(--safe-b-measured));
  }
}


/* ── 앱 레이아웃 ── */
#app,.app{display:flex;flex-direction:column;height:100%;height:100dvh;
  max-width:480px;margin:0 auto;background:#fff;overflow:hidden}

/* ── v6.0: Guest 모드 폐지 — 가입/로그인 완료(body.gopang-authed) 전에는
   #app(혼디 대화창) 자체를 그려도 보이지 않게 한다. 기존에는 환영 팝업이
   대화창 "위에" 떠 있을 뿐이라, 팝업이 닫히는 찰나나 race condition에서
   미등록 사용자가 입력창/대화 내역을 볼 수 있었다. visibility:hidden은
   레이아웃은 유지하되(JS의 getElementById 등은 정상 동작) 화면에 그리지도,
   포커스/클릭도 되지 않게 한다 — #gopang-auth-gate가 그 자리를 덮는다.
   z-index는 #app보다는 위, 가입/로그인 팝업(전화번호 입력 9999, 닉네임 단계
   동일, 기기불일치 10003, 필수백업 10004)보다는 반드시 아래여야 한다 —
   안 그러면 이 가림막이 그 팝업들까지 같이 가려버려 가입 자체가 불가능해진다
   (실사용 중 발견·수정된 버그). */
body:not(.gopang-authed) #app{visibility:hidden}
#gopang-auth-gate{
  position:fixed;inset:0;z-index:500;background:#fff;
  display:flex;align-items:center;justify-content:center;
}
body.gopang-authed #gopang-auth-gate{display:none}


/* AI 버튼 — 입력 필드 오른쪽, "AI" 텍스트 + 둥근 사각 테두리
   좌측 카메라·마이크·파일첨부 아이콘과 비슷한 크기로 축소, input-row 안에서
   세로 중앙 정렬.
   2026-07-07: PDV(개인 데이터 금고) 누적량에 따라 배경색이 연한 하늘색→
   짙은 청색으로 점점 진해지도록 변경 — "데이터가 쌓일수록 AI가 사용자를
   더 정확히 대신할 수 있다"는 것을 색으로 보여준다. 색상 자체는 JS
   (_updateAIButtonPdvColor, 아래 AI 패널 스크립트 안)가 --ai-btn-bg /
   --ai-btn-fg CSS 변수를 갱신하는 방식으로 적용한다. */
.btn-ai{
  /* 2026-07-07: AI 비서 대화창이 디폴트 화면이 되면서 별도 진입 버튼이
     더 이상 필요 없어짐 — 요소·ID는 PDV 색상 로직 등 기존 JS가 계속
     참조하므로 DOM에는 남기고 화면에서만 숨긴다. */
  display:none;
  align-items:center;justify-content:center;
  min-width:26px;height:22px;flex-shrink:0;
  align-self:center;
  border-radius:6px;
  border:1.2px solid transparent;
  background:var(--ai-btn-bg, #c9daf8);
