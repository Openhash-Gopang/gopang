  // ── 대화 연속성: 히스토리를 localStorage에 보관 (새로고침/재접속 후 이어가기) ─
  const _HISTORY_STORE_KEY = 'hondi_panel_history_v1';

  const _panelHistory = [];  // 패널 전용 대화 히스토리

  // BUG-FIX(2026-07-01): _savePanelHistory()가 저장만 하고 있었고, 그걸
