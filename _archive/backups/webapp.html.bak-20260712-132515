  // 대화가 길어질수록 매 턴마다 전체 히스토리를 그대로 다시 보내 비용이
  // 누적적으로 커지는 문제를 막기 위해, system 프롬프트는 유지하고
  // 나머지는 최근 N개 메시지(턴)만 남긴다. (2026-06-27 — 6/27 사용량 폭증
  // 원인 분석에서 발견: 패널 세션이 길어질수록 요청당 토큰이 계속 불어남)
  const _PANEL_HISTORY_MAX_MESSAGES = 20; // system 제외, user/assistant 약 10턴

  function _savePanelHistory() {
    try {
      // system 프롬프트(첫 항목)는 제외하고 저장 — 너무 길어 quota 초과 위험
      const toSave = _panelHistory.filter(m => m.role !== 'system').slice(-20);
      localStorage.setItem(_HISTORY_STORE_KEY, JSON.stringify(toSave));
    } catch {}
  }

  // 사용자 메시지 앞에는 _buildFirstContactContext()가 붙인
  // [FIRST_CONTACT: ...]/[TUTORIAL_STEP: ... [TUTORIAL_ADVANCE:N] ...] 같은
  // 내부 지시문이 실제 입력 앞에 그대로 저장돼 있다(안에 대괄호가 중첩됨).
  // BUG-FIX: _stripInternalTags의 정규식은 중첩 대괄호를 고려하지 않아
  // 첫 ']'에서 멈춰버리므로, 여기서는 괄호 깊이를 세어 가장 바깥쪽
  // '['...']' 블록을 통째로 정확히 벗겨낸다. 벗기고 나서 아무것도 안
  // 남으면(예: [INTERNAL: ...] 같은 순수 트리거 메시지) 그 자체가 표시할
  // 실제 사용자 입력이 아니었다는 뜻이므로 말풍선을 만들지 않는다.
  function _stripLeadingInternalTag(text) {
    if (typeof text !== 'string') return text;
    let s = text;
    while (s.startsWith('[')) {
      let depth = 0, i = 0;
      for (; i < s.length; i++) {
        if (s[i] === '[') depth++;
        else if (s[i] === ']') { depth--; if (depth === 0) { i++; break; } }
      }
      if (depth !== 0) break; // 괄호가 안 닫히면 원본을 건드리지 않고 중단(안전장치)
      s = s.slice(i).replace(/^\n+/, '');
    }
    return s.trim();
  }

  // 복원된 히스토리를 화면 말풍선으로도 재현 — msgList가 비어 있으면
  // openAIPanel()이 "처음 여는 것"으로 오인해 인사말을 다시 시작하므로,
  // 여기서 먼저 채워 그 오인식을 막는다. 사용자 메시지의 첨부파일(멀티모달
  // image_url 블록)은 텍스트만 뽑아 표시한다. assistant 메시지는 원문에
  // [PROFILE_SUBMIT ...] 같은 내부 태그가 섞여 저장돼 있으므로
  // _stripInternalTags로 제거한 뒤 보여준다(실시간 스트리밍 응답과 동일 처리).
  async function _replayPanelHistory() {
    let _strip = (s) => s;
    try {
      const mod = await import('./src/gopang/ai/call-ai.js');
      if (typeof mod._stripInternalTags === 'function') _strip = mod._stripInternalTags;
    } catch {}
    for (const m of _panelHistory) {
      if (m.role === 'user') {
        const raw = typeof m.content === 'string'
          ? m.content
          : (Array.isArray(m.content) ? (m.content.find(c => c.type === 'text')?.text || '(첨부파일)') : '');
        const text = _stripLeadingInternalTag(raw);
        if (text) _appendPanelMsg('user', text); // 순수 내부 트리거(정리 후 빈 문자열)는 화면에 표시하지 않음
      } else if (m.role === 'assistant') {
        _appendPanelMsg('ai', _strip(m.content));
      }
    }
  }
  // BUG-FIX(2026-07-02): 기존엔 복원된 히스토리를 화면 말풍선으로도 그대로
  // 재현했다(_replayPanelHistory 호출) — 그래서 패널을 닫았다 다시 열면
  // 지난 대화가 화면에 계속 쌓여있었다. 사용자 요청: 맥락(LLM 컨텍스트,
  // _panelHistory)은 계속 기억하되 화면은 매번 깨끗하게 시작한다. 아래
  // _replayPanelHistory() 함수 자체는 남겨두되(구조 보존, 필요시 되돌리기
  // 쉽게) 호출은 하지 않는다. _panelGreeted도 여기서 true로 만들지 않는다
  // — false로 둬야 openAIPanel()의 인사 분기가 정상적으로 발동해서,
  // §0-1-P 3번 원칙("새 대화 시작 시 이전 대화 참조")대로 AI가 저장된
  // _panelHistory 맥락을 참고해 "지난번에 ~까지 봤었죠" 식으로 자연스럽게
  // 이어서 인사한다 — 화면은 비어 보이지만 AI는 기억하고 있는 상태.
  // if (_panelHistory.length) {
  //   _replayPanelHistory();
  //   _panelGreeted = true; // 복원된 대화가 있으면 이미 인사를 나눈 상태로 취급
  // }

  // ── 구형 _sendTutorialSignal 제거됨 (BUG-2) — 신형 _tutorialSignal 사용
  function _trimPanelHistory() {
    const hasSystem = _panelHistory[0]?.role === 'system';
    const head = hasSystem ? _panelHistory.slice(0, 1) : [];
    const rest = hasSystem ? _panelHistory.slice(1) : _panelHistory.slice(0);
    if (rest.length <= _PANEL_HISTORY_MAX_MESSAGES) return;
    const trimmed = rest.slice(rest.length - _PANEL_HISTORY_MAX_MESSAGES);
    _panelHistory.length = 0;
    _panelHistory.push(...head, ...trimmed);
  }

  async function _callPanelAI(userText, bubbleEl, attached, _preTab) {
    _panelUserAborted = false; // 새 요청 시작 — 이전 취소 플래그 초기화
    const { PROVIDER_INFO, getPriorityOrder } = await import('./src/gopang/core/config.js');
    // free-model-pool.js 삭제(2026-07-01) — OR 24h쿨다운·분당예산 관리 대신
    // 혼디 제공 DeepSeek 기본 키(hondi-flash/hondi-pro)가 항상 마지막 안전망으로 붙는다.
    // v1.6 — "AI 비서" 패널은 이제 항상 AGENT-COMMON만 쓴다. PA SP는 더 이상
    // 이 패널에서 자동으로 끼어들지 않는다(설정 화면의 프로필 작성 패널
    // 전용으로 분리됨). 최초 인사·이름짓기는 _buildFirstContactContext()가
    // 1~2턴짜리 컨텍스트로만 끼워 넣는다(SP 본문에 영구히 남지 않음).
    const {
      _loadAgentCommonSP, _handleProfileTags, _stripInternalTags, _buildFirstContactContext,
      _resolveHondiTier, _parseAgentTags,
    } = await import('./src/gopang/ai/call-ai.js');
    // BUG-FIX(2026-07-02): _callPanelAI(AI 패널 — 실제로 쓰이는 주 경로)가
    // 지금까지 _parseAgentTags를 호출한 적이 없었다. 메인 채팅 전용
    // _callAIInner만 호출하고 있었고, 패널은 _stripInternalTags로 화면
    // 표시용 텍스트에서 [GWP: ...] 등을 지우기만 했을 뿐 실제로 태그를
    // "실행"하는 코드가 전혀 없었다 — GWP(K-Law 등 새 탭), SEARCH,
    // OPEN_PROFILE, P2P_INVITE 전부 AI가 말로만 하고 실제로는 아무 일도
    // 안 일어나던 근본 원인. handleExpertTag는 CFG.system 기반 게이팅이
    // 메인 채팅 전용 상태라 패널의 system(=_panelHistory[0])과 안 맞으므로
    // 별도로 판단한다.
    const { handleExpertTag, isExpertActive } = await import('./src/gopang/ai/expert-session.js');
    // HONDI-FAQ(2026-07-01 신설) — 메인 채팅과 동일한 라우터를 그대로 재사용.
    // 자세한 설계 근거는 src/gopang/ai/hondi-faq-router.js 상단 주석 참조.
    const { buildHondiFaqContext } = await import('./src/gopang/ai/hondi-faq-router.js');
    // 토큰 정책 — 패널도 메인 채팅과 "같은 종류의 응답"이므로 같은 예산을 쓴다.
    // 이전엔 패널만 1500을 따로 썼는데(메인 채팅 800), 의도된 차이인지 알 수
    // 없는 우연한 불일치였다 — 공통 정책으로 통일.
    const { TOKEN_BUDGET } = await import('./src/gopang/core/token-policy.js');
    const { MODEL_MIGRATION } = await import('./src/gopang/core/config.js');

    // CFG에서 현재 설정 읽기
    const cfg = JSON.parse(localStorage.getItem('gopang_cfg') || '{}');
    const providers = Array.isArray(cfg.providers) ? cfg.providers : [];
    const endpoint = cfg.endpoint || 'https://hondi-proxy.tensor-city.workers.dev';

    // 히스토리에 system 추가 — manifest 기반 AGENT-COMMON이 유일한 정본이다.
    // 2026-07-05: 예전에 있던 내장 _PA_SYSTEM_PROMPT 폴백(742자짜리 축약판,
    // R0/확신도 게이트 등 안전장치가 전혀 없고 라우팅도 "K-Market" 같은
    // 표시명을 써서 실제 레지스트리 id와 어긋났음)을 완전히 제거했다.
    // manifest fetch가 실패했을 때 조용히 그 폴백으로 대체하면, 사용자는
    // 오늘까지 쌓아온 모든 안전장치가 빠진 채 그 사실도 모르고 대화하게
    // 된다 — 이건 "SP가 여러 군데 동시에 존재"하는 것 중 가장 나쁜
    // 형태였다. 실패하면 조용히 저하되지 말고 명확히 실패한다.
    // BUG-FIX: 기존엔 _panelHistory.length===0으로 판단했는데, 복원된
    // 히스토리(system 메시지는 저장하지 않으므로 항상 빠져 있음)가 있으면
    // length가 0이 아니라서 system이 영영 주입되지 않는 문제가 있었다.
    // "system 메시지가 있는지"로 직접 판단하고, unshift로 맨 앞에 둔다.
    if (!_panelHistory.some(m => m.role === 'system')) {
      let effectiveSystem = cfg.system || '';
      if (!effectiveSystem) {
        try {
          effectiveSystem = await _loadAgentCommonSP();
        } catch (e) {
          console.error('[Panel] AGENT-COMMON 로드 실패:', e.message);
          effectiveSystem = '';
        }
        if (!effectiveSystem) {
          bubbleEl.textContent = 'AI비서를 불러오지 못했습니다. 네트워크 상태를 확인하시고 새로고침해 주세요.';
          return;
        }
      }
      _panelHistory.unshift({ role: 'system', content: effectiveSystem });
    }
    // 첨부파일 반영 — 이미지는 image_url 블록 + sha256, 그 외(txt/pdf/docx)는
    // pdf.js/mammoth.js로 추출한 본문 전체를 텍스트로 첨부 (2026-07-12 v2)
    let userContent = userText;
    const files = Array.isArray(attached) ? attached : (attached ? [attached] : []);
    if (files.length) {
      await Promise.all(files.map(f => Promise.all([
        f._hashPromise    ? f._hashPromise.catch(() => null)    : null,
        f._extractPromise ? f._extractPromise.catch(() => null) : null,
      ])));
      const contentBlocks = [];
      const textParts = [];
      if (userText) textParts.push(userText);
      for (const f of files) {
        if (f.isImage) {
          contentBlocks.push({ type: 'image_url', image_url: { url: f.dataUrl } });
          textParts.push(f.sha256
            ? `[첨부 이미지: "${f.name}", sha256=${f.sha256} — 정부서비스 서류 접수가 필요하면 GOV_TASK_SUBMIT_REQUEST의 documents 항목에 이 sha256을 그대로 사용하세요. 어떤 서류인지는 사진 내용과 대화 맥락으로 판단하세요.]`
            : `[첨부 이미지: "${f.name}" — sha256 계산 실패, GOV_TASK_SUBMIT_REQUEST를 만들 수 없습니다.]`);
        } else if (f.extractedText) {
          textParts.push(`[첨부파일 "${f.name}" 본문 추출 결과${f.sha256 ? ` | sha256=${f.sha256}` : ''}]\n${f.extractedText}\n[본문 추출 끝 — 위 내용을 근거로 이 파일이 어떤 서류인지 직접 판단하세요${f.sha256 ? `. GOV_TASK_SUBMIT_REQUEST의 documents 항목에는 이 sha256을 사용하세요.]` : ' (sha256 계산 실패로 GOV_TASK_SUBMIT_REQUEST에는 쓸 수 없습니다).]'}`);
        } else {
          textParts.push(`[첨부파일: "${f.name}"${f.sha256 ? ` | sha256=${f.sha256}` : ''} — 본문 추출 실패 또는 미지원 형식. 파일명과 대화 맥락으로만 판단해야 합니다.]`);
        }
      }
      const combinedText = textParts.join('\n');
      userContent = contentBlocks.length ? [{ type: 'text', text: combinedText }, ...contentBlocks] : combinedText;
    }
    // 최초 인사/이름짓기 1회성 컨텍스트 — 평생 1~2턴에만 끼워짐(멀티모달
    // 첨부가 있는 경우는 생략, 이미지 자체가 핵심 입력이므로 단순화)
    if (typeof userContent === 'string') {
      try {
        const fc = _buildFirstContactContext();
        if (fc) userContent = fc + userContent;
      } catch {}
      // HONDI-FAQ — 사용자 발화 키워드가 매칭될 때만 상세 설명을 이번 턴에만
      // 끼워 넣는다. buildHondiFaqContext()가 통째로 대괄호 블록 하나로 감싸서
      // 반환하므로, 히스토리 복원 시 _stripLeadingInternalTag가 정상적으로
      // 걸러낸다(화면에 노출되지 않음).
      try {
        const faq = await buildHondiFaqContext(userText);
        if (faq) userContent = faq + userContent;
      } catch (e) { console.warn('[Panel] HONDI-FAQ 주입 실패(무시):', e.message); }
    }
    _panelHistory.push({ role: 'user', content: userContent });
    _trimPanelHistory(); // 실제 전송 직전에 잘라서, 이번 요청부터 바로 작아진 히스토리가 나간다

    // ── 후보 생성: getPriorityOrder()로 정렬 ──────────────────────
    const priorityOrder = getPriorityOrder();
    const sorted = [...providers].sort((a, b) => {
      const ia = priorityOrder.indexOf(a?.provider);
      const ib = priorityOrder.indexOf(b?.provider);
      return (ia === -1 ? 999 : ia) - (ib === -1 ? 999 : ib);
    });

    const candidates = [];
    for (const p of sorted) {
      if (!p?.apiKey || !p?.model) continue;
      const info = PROVIDER_INFO[p.provider];
      if (!info) continue;
      candidates.push({
        provider: p.provider,
        baseUrl: (p.baseUrl || info.baseUrl).replace(/\/+$/, ''),
        url: (p.baseUrl || info.baseUrl).replace(/\/+$/, '') + '/chat/completions',
        model: p.model, key: p.apiKey,
      });
    }

    // 최종 안전망 — 혼디 제공 DeepSeek 기본 키(call-ai.js와 동일 원칙).
    // model은 실제 벤더 모델명이 아니라 "hondi-flash"/"hondi-pro" 논리 티어
    // 이름이며, worker.js가 실제 백엔드로 매핑한다. 사용자가 직접 고르지 않고,
    // 이번 턴 질문의 복잡도를 보고 call-ai.js가 자동으로 판단한다(§ 자동 승격).
    candidates.push({
      provider: 'deepseek-default',
      baseUrl: endpoint.replace(/\/+$/, ''),
      model: _resolveHondiTier(userText, _panelHistory),
      key: null,
    });

    // 모델명 교정 — deepseek-chat/reasoner는 2026-07-24 완전히 막힌다(현재는
    // deepseek-v4-flash로 투명 라우팅되는 별칭일 뿐).
    for (const c of candidates) {
      if (MODEL_MIGRATION[c.model]) c.model = MODEL_MIGRATION[c.model];
    }

    let lastErr = '';
    for (const c of candidates) {
      // BUG-FIX(2026-07-01): 아래 fetch()에 타임아웃이 전혀 없어, 서버가
      // 무응답으로 멈추면 await가 영원히 반환되지 않았다(패널 버블이 "…"에서
      // 멈추고, _tutorialSignal 락도 영구 고정되는 연쇄 원인). 연결 자체가
      // 안 열리는 경우와, 스트리밍 도중 청크가 뚝 끊기는 경우를 모두 잡기
      // 위해 "마지막 진행(연결 시도 또는 청크 수신)으로부터 N초"를 재는
      // 유휴 타임아웃을 둔다 — 매 read()마다 타이머를 리셋하므로 정상적으로
      // 느리게 스트리밍되는 응답은 끊기지 않는다.
      const _IDLE_TIMEOUT_MS = 45000;
      const _abortCtl = new AbortController();
      _panelAbortCtl = _abortCtl; // 중단 버튼이 이 candidate를 취소할 수 있도록 바깥 스코프에 노출
      let _idleTimer = setTimeout(() => _abortCtl.abort(), _IDLE_TIMEOUT_MS);
      const _resetIdle = () => { clearTimeout(_idleTimer); _idleTimer = setTimeout(() => _abortCtl.abort(), _IDLE_TIMEOUT_MS); };
      try {
        // 벤더 직접 호출은 대부분 CORS에 막힌다 — 서버를 한 번 거쳐서 보낸다.
        // 'deepseek-default'는 혼디 제공 무료 기본 키(hondi-flash/hondi-pro) —
        // key 없이 /deepseek로 직행한다(서버가 자체 키·티어별 모델 매핑 처리).
        // 그 외는 /llm/relay(BYOK).
        const res = c.provider === 'deepseek-default'
          ? await fetch(`${c.baseUrl}/deepseek`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              signal: _abortCtl.signal,
              body: JSON.stringify({
                model: c.model, messages: _panelHistory, stream: true,
                max_tokens: TOKEN_BUDGET.CHAT_REPLY,
                guid: (JSON.parse(localStorage.getItem('gopang_user_v4') || sessionStorage.getItem('gopang_user_v4') || '{}')?.ipv6) || null,
              }),
            })
          : await fetch(`${endpoint.replace(/\/+$/, '')}/llm/relay`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              signal: _abortCtl.signal,
              body: JSON.stringify({
                provider: c.provider, baseUrl: c.baseUrl, apiKey: c.key,
                model: c.model, messages: _panelHistory, stream: true,
                max_tokens: TOKEN_BUDGET.CHAT_REPLY,
              }),
            });
        _resetIdle(); // 연결 응답을 받았으니 다음 구간(스트리밍) 타이머로 리셋
        if (!res.ok) {
          clearTimeout(_idleTimer); // 이 candidate는 포기하고 다음으로 — 누수 방지
          const errBody = await res.text().catch(() => '');
          lastErr = errBody.includes('FREE_QUOTA_EXCEEDED') ? 'FREE_QUOTA_EXCEEDED' : `HTTP ${res.status}`;
          continue;
        }

        // 스트리밍 렌더
        bubbleEl.textContent = '';
        const reader = res.body.getReader();
        const dec = new TextDecoder();
        let full = '';
        let buf  = '';
        // ※ 2026-07-01 수정: 이전엔 dec.decode(value)를 stream:true 없이
        //   매 read()마다 새로 호출하고, 청크 경계에 걸친 미완성 줄을
        //   버리고 있었다(call-ai.js 메인 스트림 루프와 달리 buf 누적이
        //   없었음) — SSE data 줄이 청크 경계에서 잘릴 때마다 그 조각의
        //   텍스트가 통째로 유실되는 버그(글자 누락 — "안녕"→"녕" 등).
        //   call-ai.js의 검증된 패턴(buf += decode(stream:true), 마지막
        //   미완성 줄은 buf에 보존)으로 통일.
        while (true) {
          const { done, value } = await reader.read();
          _resetIdle(); // 청크(또는 종료)를 받을 때마다 유휴 타이머 리셋
          if (done) break;
          buf += dec.decode(value, { stream: true });
          const lines = buf.split('\n');
          buf = lines.pop();
          for (const line of lines) {
            if (!line.startsWith('data: ')) continue;
            const data = line.slice(6).trim();
            if (data === '[DONE]') break;
            try {
              const chunk = JSON.parse(data)?.choices?.[0]?.delta?.content || '';
              full += chunk;
              bubbleEl.textContent = full;
              msgList.scrollTop = msgList.scrollHeight;
            } catch {}
          }
        }
        clearTimeout(_idleTimer);
        _panelAbortCtl = null; // 스트리밍 정상 종료 — 더 이상 중단할 대상 없음
        // 히스토리에 assistant 추가
        _panelHistory.push({ role: 'assistant', content: full });
        _trimPanelHistory();
        _savePanelHistory(); // 대화 연속성 — 응답마다 즉시 저장

        // v1.3 — PROFILE_SUBMIT/SKIP/PARTIAL_SAVE/FIRST_GREETED/NAME_CAPTURED 처리.
        // bubble은 null로 넘겨 call-ai.js의 _updateStreamBubble(메인 채팅 버블 구조
        // 전용)을 건드리지 않고, 패널 버블은 아래에서 직접 textContent로 정리한다.
        // sendFn에 패널 전용 콜백을 넘겨 "인계 안착 인사"가 메인 채팅이 아니라
        // 이 패널 안에 이어서 표시되게 한다.
        // v1.3 — 화면 정리를 먼저 한다(원본 full은 그대로 _handleProfileTags에
        // 넘기므로 태그 감지에는 영향 없음). 나중에 정리하면, 인계 안착 인사가
        // 스트리밍되는 몇 초 동안 원래 버블에 PROFILE_SUBMIT 원문 JSON이 그대로
        // 보이는 깜빡임이 생긴다.
        // BUG-3 수정: textContent → innerHTML + 마크다운 렌더링 (**굵게**, \n→<br>)
        const _clean = _stripInternalTags(full);
        bubbleEl.innerHTML = _clean
          .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
          .replace(/\n/g,'<br>')
          .replace(/`([^`]+)`/g,'<code>$1</code>')
          .replace(/\*\*([^*]+)\*\*/g,'<b>$1</b>');

        let handled = false;
        try {
          handled = await _handleProfileTags(full, null, async (handoffText) => {
            // 인계 메시지를 보내기 전에 패널 히스토리부터 비워야 한다 — 그래야
            // 재귀 호출이 _panelHistory.length===0 분기를 타서 새 system
            // (AGENT-COMMON)을 다시 불러온다. 늦게 비우면 옛 PA 시스템
            // 프롬프트가 깔린 채로 인계 메시지가 처리되는 버그가 생긴다.
            _panelHistory.length = 0;
            const handoffBubble = _appendPanelMsg('ai', '…');
            handoffBubble.classList.add('streaming');
            try { await _callPanelAI(handoffText, handoffBubble); }
            finally { handoffBubble.classList.remove('streaming'); }
          });
        } catch (e) {
          console.warn('[Panel] _handleProfileTags 처리 실패(무시):', e.message);
        }
        if (handled) {
          // sendFn 콜백 안에서 이미 비웠지만, sendFn이 어떤 이유로든 호출되지
          // 않았을 경우(예: callAI 쪽 변경)를 대비한 안전망 — 비어있으면 무해한 중복.
          _panelHistory.length = 0;
          return;
        }

        // ── GWP/SEARCH/OPEN_PROFILE/P2P_INVITE 태그 실행 (2026-07-02 신설) ──
        try { _parseAgentTags(full, null, userText, _preTab); }
        catch (e) { console.warn('[Panel] _parseAgentTags 처리 실패(무시):', e.message); }

        // ── EXPERT 태그 감지 → 전문가 세션 시작 ──────────────
        // _callAIInner의 CFG.system 기반 게이팅은 메인 채팅 전용 상태를
        // 보므로 그대로 재사용할 수 없다 — 패널은 항상 AGENT-COMMON만
        // 쓰므로(§0-1 상단 주석 참조) 이미 전문가 세션이 활성화돼 있지만
        // 않다면 그냥 감지를 시도한다.
        if (!isExpertActive()) {
          handleExpertTag(full).catch(e =>
            console.warn('[Panel] EXPERT 태그 처리 실패(무시):', e.message)
          );
        }
        return;
      } catch(e) {
        clearTimeout(_idleTimer); // 타임아웃/오류 어느 경로든 타이머 누수 방지
        // 사용자가 중단(stop) 버튼을 눌러 취소한 경우 — 다음 candidate로
        // 재시도하지 않고 바로 빠져나간다(에러가 아니라 의도된 취소).
        if (e.name === 'AbortError' && _panelUserAborted) { lastErr = '__USER_CANCELLED__'; break; }
        lastErr = (e.name === 'AbortError') ? '응답 시간 초과(45초)' : e.message;
      }
    }
    _panelAbortCtl = null;
    if (lastErr === '__USER_CANCELLED__') {
      // 이미 스트리밍되던 부분 응답이 bubbleEl에 표시돼 있으므로 그대로 둔다.
    } else if (lastErr === 'FREE_QUOTA_EXCEEDED') {
      bubbleEl.innerHTML =
        '🔑 무료로 제공되는 1,000원어치 AI 사용량을 모두 사용했어요.<br>' +
        '설정에서 본인의 AI 키를 등록하시면 제한 없이 계속 쓰실 수 있어요.<br>' +
        '<button onclick="openAISettings()" ' +
        'style="margin-top:8px;padding:8px 14px;border:none;border-radius:8px;' +
        'background:#1A73E8;color:#fff;font-weight:600;cursor:pointer">AI 설정하러 가기</button>';
    } else {
      bubbleEl.textContent = 'AI 오류: ' + lastErr;
    }
  }

  // ── 전송 ─────────────────────────────────────────────
  function _setPanelGenerating(on) {
    _panelGenerating = on;
    sendBtn.classList.toggle('generating', on);
    _updatePanelSendState();
  }

  async function _sendToAI() {
    const text = input.value.trim();
    const attachedList = _aiPanelAttachedFiles.slice();
    if (!text && !attachedList.length) return;
    input.value = ''; input.style.height = 'auto';
    _setPanelGenerating(true);
    const attachLabel = attachedList.length
      ? (attachedList.length === 1
          ? (attachedList[0].isImage ? '(사진 첨부)' : `(파일 첨부: ${attachedList[0].name})`)
          : `(파일 ${attachedList.length}개 첨부)`)
      : '';
    _appendPanelMsg('user', text || attachLabel);
    _clearAttachPreview();

    const aiBubble = _appendPanelMsg('ai', '…');
    aiBubble.classList.add('streaming');
    try {
      await _callPanelAI(text, aiBubble, attachedList);
    } catch(e) {
      aiBubble.textContent = 'AI 오류: ' + e.message;
    }
    aiBubble.classList.remove('streaming');
    _setPanelGenerating(false);
  }

  // 중단(stop) — 응답 생성 중 전송 버튼을 누르면 진행 중인 요청을 취소한다.
  function _stopPanelGeneration() {
    if (!_panelGenerating) return;
    _panelUserAborted = true;
    if (_panelAbortCtl) _panelAbortCtl.abort();
  }

  sendBtn.addEventListener('click', () => {
    if (_panelGenerating) _stopPanelGeneration();
    else _sendToAI();
  });
  input.addEventListener('keydown', e => {
    // 한글 IME 조합 확정 Enter와 실제 전송 Enter가 겹쳐 이중 전송되는 것을 방지
    if (e.key === 'Enter' && !e.shiftKey && !e.isComposing && e.keyCode !== 229) {
      e.preventDefault();
      if (!_panelGenerating) _sendToAI();
    }
  });
})();
</script>

<!-- ── "혼디야" 음성 호출어(wake word) ──────────────────────
     항상 듣고 있다가 "혼디야"가 들리면 AI 비서 패널을 열고 곧바로
     이어지는 발화를 듣는다. 좌측 1회용 마이크(btn-mic)나 AI 패널
     마이크(ai-panel-mic-btn)가 사용 중일 때는 마이크 장치 점유 충돌을
     피하기 위해 잠시 멈추고, 두 마이크가 모두 꺼지면 다시 대기한다.
     브라우저 정책상 마이크 권한이 허용된 뒤에만 상시 대기를 시작한다
     (권한 요청 자체는 사용자 동작 없이 자동으로 띄우지 않는다). -->
<script>
(function () {
  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SR) return; // 미지원 브라우저는 조용히 비활성화

  const WAKE_PATTERN = /혼\s*디\s*야/; // "혼디야" — 사이 띄어쓰기 변형 허용
  const WAKE_RETRIGGER_COOLDOWN_MS = 8000; // 짧은 간격 재트리거 방지(되먹임·오인식 대비)
  let _lastWakeAt = 0;
  let recognition = null;
  let wakeActive = false; // 호출어 대기 루프를 의도적으로 켜둔 상태인지
  let suspended  = false; // 다른 마이크 사용 중이라 일시 정지된 상태인지

  // ※ 2026-06-28 수정: 끝난 이유(정상 침묵 vs 지속적 오류)를 가리지 않고
  // 150ms마다 무조건 재시작하던 것이 버그였다. 네트워크가 끊긴 상태(비행기
  // 모드 등)에서는 인식이 즉시 실패→onend→재시작을 무한 반복하는데, 매번
  // recognition.start()를 새로 호출할 때마다 크롬이 "사이트에서 마이크를
  // 사용 중입니다" 알림을 다시 띄워서, 사용자에게는 알 수 없는 알림이
  // 몇 초 간격으로 영원히 반복되는 것처럼 보였다(실제로는 알림이 아니라
  // 매번 새로 뜨는 같은 시스템 알림이었음).
  let _consecutiveErrors = 0;
  const _BASE_RESTART_DELAY_MS = 150;
  const _MAX_RESTART_DELAY_MS  = 30000;

  function isOtherMicBusy() {
    const a = document.getElementById('btn-mic');
    const b = document.getElementById('ai-panel-mic-btn');
    return !!((a && a.classList.contains('mic-recording')) || (b && b.classList.contains('mic-recording')));
  }

  function createRecognition() {
    const r = new SR();
    r.lang = document.documentElement.lang === 'ko' ? 'ko-KR' : (navigator.language || 'ko-KR');
    // ※ 2026-06-29: continuous:false였을 때, 침묵이 몇 초만 지나도(에러 없이
    // 정상적으로) 세션이 끝나고 onend에서 곧바로 재시작했다 — 에러가 아예
    // 없는 "성공" 경로라서 _consecutiveErrors 기반 백오프가 전혀 개입하지
    // 않았고, 매 재시작마다 OS의 "마이크 사용 중" 알림이 다시 떴다(몇 초
    // 간격으로 영원히 반복되는 것처럼 보임). 호출어 대기는 원래 "계속
    // 듣고 있어야" 하는 용도라 continuous:true가 맞다 — 세션이 자연스럽게
    // 자주 끝나지 않으니 재시작 자체가 훨씬 드물어진다.
    r.continuous = true;
    r.interimResults = false;

    r.onresult = (event) => {
      _consecutiveErrors = 0; // 정상적으로 결과를 받았으니 실패 횟수 리셋
      // continuous:true에서는 발화마다 결과가 새 인덱스에 쌓인다 — 항상
      // results[0]만 보면 두 번째 발화부터 영원히 무시된다(continuous:true로
      // 바꾸면서 같이 고침). 가장 최근 결과만 본다.
      const last = event.results?.[event.results.length - 1];
      const text = last?.[0]?.transcript || '';
      if (WAKE_PATTERN.test(text)) _onWakeDetected();
    };
    r.onerror = (event) => {
      // no-speech/aborted는 정상적인 일시 정지일 뿐 — 실패로 치지 않음
      if (event?.error === 'no-speech' || event?.error === 'aborted') return;
      _consecutiveErrors++;
    };
    r.onend = () => {
      if (!wakeActive || suspended) return;

      // 네트워크 자체가 끊겨 있으면(비행기 모드 등) 짧은 간격으로 재시도해도
      // 매번 실패만 반복하며 마이크 알림만 계속 새로 띄운다 — 다시 온라인이
      // 될 때까지 재시도를 멈추고 'online' 이벤트를 기다린다.
      if (typeof navigator.onLine === 'boolean' && !navigator.onLine) {
        window.addEventListener('online', () => {
          _consecutiveErrors = 0;
          startListening();
        }, { once: true });
        return;
      }

      // 온라인인데도 계속 실패하면(서버 일시 장애 등) 지수 백오프로 재시도
      // 간격을 늘려 마이크 알림이 끝없이 반복되는 것을 막는다.
      const delay = _consecutiveErrors > 3
        ? Math.min(_BASE_RESTART_DELAY_MS * Math.pow(2, _consecutiveErrors - 3), _MAX_RESTART_DELAY_MS)
        : _BASE_RESTART_DELAY_MS;
      setTimeout(startListening, delay);
    };
    return r;
  }

  function startListening() {
    if (!wakeActive || suspended) return;
    recognition = createRecognition();
    try { recognition.start(); } catch (e) { /* 무시 */ }
  }

  function _onWakeDetected() {
    const now = Date.now();
    if (now - _lastWakeAt < WAKE_RETRIGGER_COOLDOWN_MS) return; // 짧은 간격 재트리거 — 되먹임/오인식 방지
    _lastWakeAt = now;
    if (typeof window.openAIPanel === 'function') window.openAIPanel();
    // 패널이 열리는 애니메이션 시간(약 0.4s) 뒤 곧바로 다음 발화를 듣기 시작한다.
    setTimeout(() => {
      const micBtn = document.getElementById('ai-panel-mic-btn');
      if (micBtn && !micBtn.classList.contains('mic-recording')) micBtn.click();
    }, 450);
  }

  function pauseWake()  { suspended = true;  try { recognition?.stop(); } catch (e) {} }
  function resumeWake() { suspended = false; if (wakeActive) startListening(); }

  // 다른 마이크가 켜지면 호출어 대기를 잠시 멈추고, 꺼지면 다시 시작
  ['btn-mic', 'ai-panel-mic-btn'].forEach(id => {
    document.getElementById(id)?.addEventListener('click', () => {
      setTimeout(() => { isOtherMicBusy() ? pauseWake() : resumeWake(); }, 50);
    });
  });

  function startWake() {
    if (wakeActive) return;
    wakeActive = true;
    if (!isOtherMicBusy()) startListening();
  }

  // ※ 2026-06-29: 자동 시작 트리거를 모두 제거함 — 권한이 이미 허용된
  // 상태(설치형 PWA 등)거나 마이크 버튼을 누르기만 해도 호출어 대기가
  // 자동으로 켜졌는데, 그게 몇 초 간격으로 끝없이 재시작하며 안드로이드의
  // "마이크 사용 중" 알림을 반복적으로 띄우는 원인이었다. 이제 startWake()는
  // 정의돼 있지만 아무 데서도 자동으로 호출되지 않는다 — 항시 대기하는
  // 호출어("혼디야") 기능은 당분간 비활성 상태다.

  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'hidden') pauseWake();
    else resumeWake();
  });
})();
</script>



