<meta charset="UTF-8">
<script>
// ── PC 접속 차단 가드 ────────────────────────────────────
// 혼디는 스마트폰 전용 앱. PDV(개인 일상/업무 기록)는 휴대폰에만 저장되어야
// 하며, PC에 남으면 다른 사람이 탈취할 위험이 있다. PC는 ai-setup.html 같은
// 특수 목적(LLM API 키 입력 등)에만 쓰여야 한다.
// 개발/테스트 우회: 콘솔에서 localStorage.setItem('gopang_dev_bypass','true')
//
// 🚧🚧🚧 TEMP-DISABLED — 개발 중 PC 테스트를 위해 통째로 꺼둠 🚧🚧🚧
// 개발 끝나면 아래 "if (true)" 한 줄을 지우거나 false로 바꿔서 원복할 것.
(function () {
  if (true) return; // ← 🚧 이 줄만 지우면 원래대로 복구됨 🚧
  const isMobile = /Android|iPhone|iPad|iPod|Mobile/i.test(navigator.userAgent || '');
  if (isMobile) return;

  let devBypass = false;
  try { devBypass = localStorage.getItem('gopang_dev_bypass') === 'true'; } catch {}
  if (devBypass) {
    console.warn('[Gopang] 개발자 우회 플래그 활성 — PC 접속 차단을 건너뜁니다.');
    return;
  }

  document.write(
    '<div style="position:fixed;inset:0;z-index:99999;background:#fff;' +
    'display:flex;align-items:center;justify-content:center;padding:24px;' +
    'box-sizing:border-box;font-family:\'Pretendard\',-apple-system,' +
    'BlinkMacSystemFont,sans-serif">' +
      '<div style="max-width:380px;text-align:center">' +
        '<p style="font-weight:700;font-size:18px;margin:0 0 14px;color:#111827">' +
          '스마트폰 전용 서비스입니다' +
        '</p>' +
        '<p style="font-size:14px;color:#374151;line-height:1.7;margin:0 0 8px">' +
          '혼디는 개인정보 보호를 위해 스마트폰에서만 사용할 수 있습니다.<br>' +
          'PC에서는 대화·기록이 다른 사람에게 노출될 위험이 있어 접속을 제한합니다.' +
        '</p>' +
        '<p style="font-size:13px;color:#6b7280;line-height:1.6;margin:0">' +
          'AI 비서는 가입 즉시 무료로 자동 제공되며, 별도의 PC 설정이 필요 없습니다.' +
        '</p>' +
      '</div>' +
    '</div>'
  );
  document.close();
  throw new Error('[Gopang] PC 접속 차단 — webapp.html은 스마트폰 전용입니다.');
})();
</script>
