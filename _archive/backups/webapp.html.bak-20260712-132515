    let timer = null, longPressed = false, startX = 0, startY = 0;
    function start(x, y) {
      longPressed = false; startX = x; startY = y;
      timer = setTimeout(() => { timer = null; longPressed = true; onPress(); }, ms);
    }
    function move(x, y) {
      if (timer && (Math.abs(x - startX) > 10 || Math.abs(y - startY) > 10)) {
        clearTimeout(timer); timer = null;
      }
    }
    function cancel() { if (timer) { clearTimeout(timer); timer = null; } }
