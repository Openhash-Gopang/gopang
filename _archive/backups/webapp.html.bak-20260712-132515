<script>
// ── 알림 소리 설정 ────────────────────────────────────────
function _initPushSoundUI() {
  const saved = localStorage.getItem('gopang_push_sound') || 'ping';
  const radios = document.querySelectorAll('input[name="push-sound"]');
  radios.forEach(r => { if (r.value === saved) r.checked = true; });

  // 구독 상태 확인 → 토글 반영
  if ('serviceWorker' in navigator && 'PushManager' in window) {
    navigator.serviceWorker.ready.then(reg => {
      reg.pushManager.getSubscription().then(sub => {
        _setPushToggle(!!sub);
      });
    });
  }
}

function _savePushSound(val) {
  localStorage.setItem('gopang_push_sound', val);
  // 소리 선택 시 자동 미리듣기
  if (val !== 'none') new Audio('/assets/sounds/' + val + '.mp3').play().catch(()=>{});
  // 구독 중이면 서버에도 업데이트
  const user = JSON.parse(localStorage.getItem('gopang_user_v4') || 'null');
  if (!user?.ipv6) return;
  navigator.serviceWorker?.ready.then(reg =>
    reg.pushManager.getSubscription().then(sub => {
      if (!sub) return;
      fetch('https://hondi-proxy.tensor-city.workers.dev/push/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ guid: user.ipv6, subscription: sub.toJSON(), sound: val }),
      });
    })
  );
}

function _testPushSound() {
  const val = document.querySelector('input[name="push-sound"]:checked')?.value || 'ping';
  if (val === 'none') return;
  const audio = new Audio(`/assets/sounds/${val}.mp3`);
  audio.play().catch(() => {});
}

// 토글 상태 시각 반영
function _setPushToggle(on) {
  const toggle = document.getElementById('push-toggle');
  const track  = document.getElementById('push-toggle-track');
  const thumb  = document.getElementById('push-toggle-thumb');
  const status = document.getElementById('push-status');
  if (!toggle) return;
  toggle.disabled        = false;
  toggle.style.opacity   = '1';
  toggle.checked        = on;
  track.style.background  = on ? '#1A73E8' : '#e5e7eb';
  thumb.style.transform   = on ? 'translateX(20px)' : 'translateX(0)';
  if (status) status.textContent = on ? '알림이 활성화되어 있습니다' : '';
}

// 누른 즉시 — 결과를 기다리는 동안 "처리 중" 상태로 바로 반응
function _setPushToggleLoading() {
  const toggle = document.getElementById('push-toggle');
  const status = document.getElementById('push-status');
  if (toggle) { toggle.disabled = true; toggle.style.opacity = '0.5'; }
  if (status) status.textContent = '처리 중…';
}

async function _togglePush(on) {
  const status = document.getElementById('push-status');
  const user   = JSON.parse(localStorage.getItem('gopang_user_v4') || 'null');
  _setPushToggleLoading(); // 누른 즉시 시각적 반응

  if (!('serviceWorker' in navigator) || !('PushManager' in window)) {
    if (status) status.textContent = '이 브라우저는 푸시 알림을 지원하지 않습니다';
    _setPushToggle(false); return;
  }

  if (on) {
    // 켜기
    if (!user?.ipv6) { if (status) status.textContent = '먼저 로그인해 주세요'; _setPushToggle(false); return; }
    try {
      if (status) status.textContent = '권한 요청 중…';
      const { requestPushSubscription } = await import('/src/gopang/services/push.js');
      const result = await requestPushSubscription(user.ipv6);
      if (!result.ok) throw new Error(result.reason || '구독 실패');
      _setPushToggle(true);
    } catch(e) {
      if (status) status.textContent = '알림 권한이 거부됐거나 오류가 발생했습니다';
      _setPushToggle(false);
      console.warn('[Push]', e.message);
    }
  } else {
    // 끄기
    try {
      const reg = await navigator.serviceWorker.ready;
      const sub = await reg.pushManager.getSubscription();
      if (sub) await sub.unsubscribe();
      // 서버에서도 삭제
      if (user?.ipv6) {
        await fetch('https://hondi-proxy.tensor-city.workers.dev/push/subscribe', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ guid: user.ipv6, subscription: null, sound: 'none', unsubscribe: true }),
        }).catch(()=>{});
      }
      _setPushToggle(false);
    } catch(e) {
      console.warn('[Push unsubscribe]', e.message);
      _setPushToggle(false);
    }
  }
}

function _urlBase64ToUint8Array(base64String) {
  const padding = '='.repeat((4 - base64String.length % 4) % 4);
  const base64  = (base64String + padding).replace(/-/g, '+').replace(/_/g, '/');
  const raw     = atob(base64);
  return Uint8Array.from([...raw].map(c => c.charCodeAt(0)));
}

// 설정 창 열릴 때 초기화
document.addEventListener('DOMContentLoaded', _initPushSoundUI);
// 설정 패널이 동적으로 열리는 경우 대비
if (document.readyState === 'complete') _initPushSoundUI();
