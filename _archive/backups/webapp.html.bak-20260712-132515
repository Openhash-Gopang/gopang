        console.info('[Auth] 셀피 파일 선택:', event?.target?.files?.[0]?.name);
      }

      // ── 계정 삭제 슬라이드아웃 (2026-07-02 신설) ──────────
      // 로컬 전화번호(e164, 예: +821012345678)와 사용자가 입력한 국내
      // 형식(01012345678 등)을 비교하기 위한 정규화 — 뒷자리가 일치하면
      // 통과시킨다(국가번호·맨 앞 0 유무를 신경 쓰지 않아도 되게).
      function _normPhoneDigits(s) { return (s || '').replace(/\D/g, ''); }
      function _phoneMatches(inputVal, storedE164) {
        const a = _normPhoneDigits(inputVal).replace(/^0+/, '');
        const b = _normPhoneDigits(storedE164);
        return a.length >= 8 && b.endsWith(a);
      }

      function openAccountDelete() {
        const idInput    = document.getElementById('ad-input-id');
        const phoneInput = document.getElementById('ad-input-phone');
        const errEl      = document.getElementById('ad-error');
        if (idInput)    idInput.value = '';
        if (phoneInput) phoneInput.value = '';
        if (errEl)      errEl.style.display = 'none';
        _checkAccountDeleteInput();
        document.getElementById('account-delete-overlay')?.classList.add('open');
      }
      function closeAccountDelete() {
        document.getElementById('account-delete-overlay')?.classList.remove('open');
      }

      function _checkAccountDeleteInput() {
        const stored = JSON.parse(localStorage.getItem('gopang_user_v4') || sessionStorage.getItem('gopang_user_v4') || '{}');
        const idInput    = document.getElementById('ad-input-id');
        const phoneInput = document.getElementById('ad-input-phone');
        const btn        = document.getElementById('btn-account-delete-confirm');
        if (!idInput || !phoneInput || !btn) return;

        const idMatch    = !!(stored.nickname && idInput.value.trim() === stored.nickname.trim());
        const phoneMatch = !!(stored.e164 && _phoneMatches(phoneInput.value, stored.e164));

        if (idMatch && phoneMatch) {
          btn.disabled = false;
          btn.style.background = '#dc2626';
          btn.style.cursor = 'pointer';
        } else {
          btn.disabled = true;
          btn.style.background = '#fca5a5';
          btn.style.cursor = 'not-allowed';
        }
      }

      async function _confirmAccountDelete() {
        const btn   = document.getElementById('btn-account-delete-confirm');
        const errEl = document.getElementById('ad-error');
        if (!btn || btn.disabled) return;
        if (!confirm(
          '정말 계정을 삭제하시겠어요?\n\n' +
          '서버에 있던 전화번호·연결 정보만 지워집니다. 이 기기의 대화·기록은\n' +
          '그대로 남아있으니, 같은 번호로 다시 가입하면 지금 상태로 이어서 쓰실 수 있어요.'
        )) return;

        const originalLabel = btn.textContent;
        btn.disabled = true;
        btn.textContent = '삭제 중...';
        if (errEl) errEl.style.display = 'none';

        try {
          const stored = JSON.parse(localStorage.getItem('gopang_user_v4') || sessionStorage.getItem('gopang_user_v4') || '{}');
          const ok = await window._deleteMyProfile(stored.e164 || '');
          if (ok) {
            closeAccountDelete();
            alert('계정이 삭제됐어요.\n\n이 기기의 기록은 남아있으니, 언제든 같은 번호로 다시 가입하시면 이어서 쓰실 수 있어요.');
            location.reload();
            return;
          }
        } catch (e) {
          if (errEl) { errEl.textContent = '오류: ' + e.message; errEl.style.display = 'block'; }
        }
        btn.disabled = false;
        btn.textContent = originalLabel;
        _checkAccountDeleteInput();
      }
      window.openAccountDelete  = openAccountDelete;
      window.closeAccountDelete = closeAccountDelete;
      window._checkAccountDeleteInput = _checkAccountDeleteInput;
      window._confirmAccountDelete    = _confirmAccountDelete;
      </script>

