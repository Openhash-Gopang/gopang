<script type="module">
import { startScanner, stopScanner, lookupProfile, analyzePhoto }
  from './src/gopang/ai/hondi-scanner.js';

let _profileUrl = null;

/* ── 스캔 시작 헬퍼 ── */
let _scannerActive = false;  // 중복 시작 방지 플래그

function _startScan() {
  if (_scannerActive) stopScanner();  // 이미 실행 중이면 먼저 정지
  _scannerActive = true;
  const video   = document.getElementById('hs-video');
  const canvas  = document.getElementById('hs-canvas');
  const overlay = document.getElementById('hs-overlay');

  startScanner(video, canvas, overlay,
    /* 인식 성공 */
    async (shortId, version) => {
      _scannerActive = false;  // 스캐너 완전 종료 — 재인식 없음
      _setStatus('프로필 조회 중...');
      try {
        // ── 로컬 프로필 라우팅 테이블 ──
        const LOCAL_PROFILES = {
          '5zvxrthQVkz': { name: '혼디', handle: 'hondi', url: '/profiles/5zvxrthQVkz.html' },
        };
        let p;
        if (LOCAL_PROFILES[shortId]) {
          p = LOCAL_PROFILES[shortId];
        } else {
          p = await lookupProfile(shortId, version);
        }
        _profileUrl = p.url;
        document.getElementById('hs-result-name').textContent    = p.name || p.handle;
        document.getElementById('hs-result-handle').textContent  = '@' + p.handle;
        document.getElementById('hs-result-version').textContent =
          '혼디 코드 ' + version + ' · ID ' + shortId;
        document.getElementById('hs-result').style.display = 'flex';
        // 1.2초 후 자동 이동
        setTimeout(() => { if (_profileUrl) window.location.href = _profileUrl; }, 1200);
      } catch (e) {
        // 프로필 조회 실패 — 다시 스캔하지 않고 오류 표시만
        _setStatus('❌ ' + e.message);
        // 사용자가 직접 hsRescan 버튼을 눌러야 재시도 가능
      }
    },
    /* 상태 메시지 */
    (msg) => _setStatus(msg)
  );
}

function _setStatus(msg) {
  const el = document.getElementById('hs-status');
  if (el) el.textContent = msg;
}

/* ── 공개 함수 ── */
window.openHondiScanner = async function () {
  _scannerActive = false;  // 상태 초기화
  const ov = document.getElementById('hondi-scanner-overlay');
  ov.style.display = 'flex';
  document.getElementById('hs-result').style.display = 'none';
  const fb0 = document.getElementById('hs-send-photo-btn');
  if (fb0) fb0.style.display = 'none';
  _setStatus('카메라를 시작하는 중...');
  try {
    await _startScan();
  } catch (e) {
    // 권한 거부면 닫기 버튼만 남기고 오버레이 유지 (메시지는 hs-status에 표시됨)
    if (e.name === 'NotAllowedError' || e.name === 'PermissionDeniedError') {
      // 상태 바를 빨갛게 강조
      const st = document.getElementById('hs-status');
      if (st) st.style.color = '#ff6b6b';
    }
  }
};

window.closeHondiScanner = function () {
  _scannerActive = false;
  stopScanner();
  document.getElementById('hondi-scanner-overlay').style.display = 'none';
};

window.hsGoProfile = function () {
  if (_profileUrl) window.location.href = _profileUrl;
};

window.hsRescan = function () {
  stopScanner();           // 혹시 남아있는 스트림 정리
  _scannerActive = false;
  document.getElementById('hs-result').style.display = 'none';
  const fb1 = document.getElementById('hs-send-photo-btn');
  if (fb1) fb1.style.display = 'none';
  _setStatus('다시 스캔합니다...');
  _startScan();
};

/* ── 사진 촬영 (보조) ── */
window.hsTakePhoto = function () {
  stopScanner();
  const video  = document.getElementById('hs-video');
  const canvas = document.getElementById('hs-canvas');
  canvas.width  = video.videoWidth;
  canvas.height = video.videoHeight;
  const ctx = canvas.getContext('2d');
  ctx.drawImage(video, 0, 0);
  const imgData = ctx.getImageData(0, 0, canvas.width, canvas.height);

  _setStatus('사진 분석 중...');
  analyzePhoto(imgData,
    async (shortId, version) => {
      try {
        const LOCAL_PROFILES = {
          '5zvxrthQVkz': { name: '혼디', handle: 'hondi', url: '/profiles/5zvxrthQVkz.html' },
        };
        const p = LOCAL_PROFILES[shortId] || await lookupProfile(shortId, version);
        _profileUrl = p.url;
        document.getElementById('hs-result-name').textContent    = p.name || p.handle;
        document.getElementById('hs-result-handle').textContent  = '@' + p.handle;
        document.getElementById('hs-result-version').textContent =
          '혼디 코드 ' + version + ' · ID ' + shortId;
        document.getElementById('hs-result').style.display = 'flex';
      } catch (e) {
        _setStatus('❌ 코드를 못 찾았어요');
        const fb = document.getElementById('hs-send-photo-btn');
        if (fb) fb.style.display = 'block';
      }
    },
    (msg) => _setStatus(msg)
  );
};

/* ── 코드 인식 실패 시 폴백: 방금 찍은 사진을 그냥 채팅 첨부로 보낸다.
   camera-input의 기존 onchange="handleFileSelect(event)" 경로를 그대로
   재사용 — handleFileSelect 내부 구현을 몰라도 안전하게 동일 경로를 탄다. */
window.hsSendAsAttachment = function () {
  const canvas = document.getElementById('hs-canvas');
  if (!canvas || !canvas.width) return;
  canvas.toBlob((blob) => {
    if (!blob) return;
    const file = new File([blob], 'hondi-scan-' + Date.now() + '.jpg', { type: 'image/jpeg' });
    try {
      const dt = new DataTransfer();
      dt.items.add(file);
      const fileInput = document.getElementById('camera-input');
      fileInput.files = dt.files;
      fileInput.dispatchEvent(new Event('change', { bubbles: true }));
    } catch (e) {
      console.error('[HondiScanner] 사진 첨부 폴백 실패', e);
    }
  }, 'image/jpeg', 0.9);
  closeHondiScanner();
};
</script>


<script>
// ── 설정 드로어 스크롤 중 키패드 방지 ──
(function() {
  function preventScrollFocus() {
    const drawer = document.querySelector('.settings-drawer');
    if (!drawer) return;
    let isScrolling = false;
    let scrollTimer = null;

    drawer.addEventListener('scroll', function() {
      isScrolling = true;
      clearTimeout(scrollTimer);
      scrollTimer = setTimeout(function() {
        isScrolling = false;
      }, 150);
    }, { passive: true });

    // 스크롤 중 input focus 차단
    drawer.addEventListener('touchstart', function(e) {
      if (isScrolling) {
        const target = e.target;
        if (target.tagName === 'INPUT' || target.tagName === 'TEXTAREA') {
          e.preventDefault();
        }
      }
    }, { passive: false });
  }

  // 설정 패널 열릴 때마다 적용
  document.addEventListener('DOMContentLoaded', function() {
    preventScrollFocus();
    // 동적으로 생성되는 경우 대비
    const observer = new MutationObserver(function() {
      preventScrollFocus();
    });
    observer.observe(document.body, { childList: true, subtree: false });
  });
})();
</script>
