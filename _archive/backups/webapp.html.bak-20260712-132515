<!-- ── 바텀시트 스와이프-다운으로 닫기 ── -->
<script>
(function () {
  function setupSwipeToClose(overlay) {
    const sheet  = overlay.querySelector('.settings-sheet');
    const handle = overlay.querySelector('.sheet-handle');
    if (!sheet || !handle) return;

    let startY = 0, lastY = 0, dragging = false;

    function start(y) {
      dragging = true;
      startY = lastY = y;
      sheet.style.transition = 'none';
    }
    function move(y) {
      if (!dragging) return;
      lastY = y;
      const delta = Math.max(0, lastY - startY);
      sheet.style.transform = 'translateY(' + delta + 'px)';
    }
    function end() {
      if (!dragging) return;
      dragging = false;
      sheet.style.transition = '';
      const delta = Math.max(0, lastY - startY);
      sheet.style.transform = '';
      // 80px 이상 끌어내리면 기존 닫기 로직(backdrop 클릭 핸들러)을 그대로 재사용
      if (delta > 80) overlay.click();
    }

    handle.addEventListener('touchstart', (e) => start(e.touches[0].clientY), { passive: true });
    handle.addEventListener('touchmove',  (e) => move(e.touches[0].clientY),  { passive: true });
    handle.addEventListener('touchend', end);

    // 데스크탑 마우스 드래그(테스트용)도 함께 지원
    handle.addEventListener('mousedown', (e) => start(e.clientY));
    window.addEventListener('mousemove', (e) => move(e.clientY));
    window.addEventListener('mouseup', end);
  }

  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.settings-overlay').forEach(setupSwipeToClose);
  });
})();
</script>

<!-- ── 안드로이드 하단 내비게이션 바 높이 실측 ──
     env(safe-area-inset-bottom)이 안드로이드 standalone PWA에서 0으로
     잘못 보고되는 기기가 많아(특히 삼성), 고정값 추측 대신 실제
     기기에서 레이아웃 뷰포트와 보이는 뷰포트의 차이를 직접 측정한다.
     standalone 모드에는 주소창이 없으므로 이 차이는 곧 내비게이션 바
     높이다. 키보드가 올라온 경우(차이가 매우 큼)는 80px 상한으로 걸러
     낸다 — 실제 내비게이션 바는 그보다 훨씬 작다.
     ※ diff가 0 이하로 측정되는 것(제스처 내비게이션 기기 등 — 실제로
     여백이 필요 없는 경우)도 "측정 성공"으로 보고 0px를 명시적으로
     반영한다. 예전에는 이 경우 그냥 return해버려서 CSS의 48px
     초기값/하한이 계속 남아 입력창이 불필요하게 떠 보이는 버그가
     있었다. 80px를 넘는 큰 값(키보드 등)만 측정 실패로 보고 직전 값을
     그대로 둔다. -->
<script>
(function () {
  const NAVBAR_MAX = 80; // 이보다 크면 키보드 등 다른 원인으로 간주, 무시(직전 값 유지)

  function measure() {
    if (!window.visualViewport) return;
    const diff = window.innerHeight - window.visualViewport.height;
    if (diff > NAVBAR_MAX) return; // 키보드로 추정되는 큰 값은 무시, 직전 값 유지
    const navHeight = Math.max(diff, 0); // 음수(반올림 오차 등)는 0으로 처리
    document.documentElement.style.setProperty('--safe-b-measured', navHeight + 'px');
  }

  measure();
  window.visualViewport?.addEventListener('resize', measure);
  window.addEventListener('orientationchange', () => setTimeout(measure, 250));
})();
</script>


<!-- ── 좌/우 메뉴 열기·닫기 ──
     settings.js의 설정 시트(.settings-overlay)와는 완전히 별개.
     - 좌측 메뉴(left-menu.html)  : 최근 대화 상대 / GDC / 알림 등 — 왼쪽 가장자리 스와이프
     - 우측 메뉴(right-menu.html): K-Law, K-Tax, K-School 등 하위 시스템 목록 — 오른쪽 가장자리 스와이프
     두 iframe 모두 페이지 로드 시점에 미리 로드해 둔다(eager load) —
     처음 열 때 로딩과 슬라이드 애니메이션이 겹쳐 깜박이는 문제 방지. -->
<script>
function openLeftMenu() {
  document.getElementById('left-menu-overlay')?.classList.add('open');
  // BUG-FIX(2026-07-01): 이 자리에서 직접 _tutorialSignal을 호출하는 코드가
  // 있었으나(구 _tutorialMenuAction), 이후 다른 스크립트 블록의
  // window.openLeftMenu 래퍼가 "신호가 안 나간다"는 오진단 아래 동일한
  // 신호를 한 번 더 호출하도록 추가되면서, 메뉴를 열 때마다 튜토리얼 신호가
  // 정확히 두 번씩 발동해 AI 응답이 통째로 중복되는 원인이 되었다.
  // BUG-FIX(2026-07-02): 신호 발동 시점 자체도 "연다" 시점이라 메뉴가 화면을
  // 가린 채로 AI 피드백이 나오는 문제가 있어, 아래 래퍼를 closeLeftMenu/
  // closeRightMenu 쪽으로 옮겼다(메뉴를 "닫을 때" 발동). 여기 open*은
  // 순수 UI 토글만 수행한다.
}
function closeLeftMenu()  { document.getElementById('left-menu-overlay')?.classList.remove('open'); }
function openRightMenu() {
  document.getElementById('right-menu-overlay')?.classList.add('open');
  // BUG-FIX(2026-07-01/07-02): 위 openLeftMenu와 동일한 이유 — 상세 주석 참고.
}
function closeRightMenu() { document.getElementById('right-menu-overlay')?.classList.remove('open'); }

function openUserManual()  { document.getElementById('manual-overlay')?.classList.add('open'); }
function closeUserManual() { document.getElementById('manual-overlay')?.classList.remove('open'); }
function openTermsOfUse()  { document.getElementById('terms-overlay')?.classList.add('open'); }
function closeTermsOfUse() { document.getElementById('terms-overlay')?.classList.remove('open'); }

// PDV — 좌측 메뉴(left-menu.html)에서 parent.openPDV() 형태로 직접 호출된다.
// (좌/우 메뉴, 매뉴얼 iframe과 동일하게 same-origin이므로 postMessage 대신 부모 함수 직접 호출)
function openPDV()  {
  document.getElementById('left-menu-overlay')?.classList.remove('open');
  document.getElementById('pdv-overlay')?.classList.add('open');
}
function closePDV() { document.getElementById('pdv-overlay')?.classList.remove('open'); }

window.openLeftMenu   = openLeftMenu;
window.closeLeftMenu  = closeLeftMenu;
window.openRightMenu  = openRightMenu;
window.closeRightMenu = closeRightMenu;
window.openUserManual  = openUserManual;
window.closeUserManual = closeUserManual;
window.openTermsOfUse  = openTermsOfUse;
window.closeTermsOfUse = closeTermsOfUse;
window.openPDV  = openPDV;
window.closePDV = closePDV;
</script>

<!-- ── 가장자리 스와이프로 메뉴 열기 (좌/우/위) ──
     안드로이드는 화면 가장자리에서 시작하는 스와이프를 기본 "뒤로가기"
     제스처(좌/우)나 당겨서 새로고침(위)으로 가로채 페이지를 이탈시킨다.
     아래 핸들러가 그 제스처를 선점해서 기본 동작을 막고, 대신 패널을
     열도록 한다.
       · 왼쪽 가장자리 → 오른쪽으로 스와이프 → 좌측 메뉴(left-menu.html)
       · 오른쪽 가장자리 → 왼쪽으로 스와이프 → 우측 메뉴(right-menu.html, 하위 시스템)
       · 위쪽 가장자리 → 아래로 스와이프 → 사용자 매뉴얼(user-manual.html)
     ※ settings.js가 그리는 설정 시트는 2026-07-08 상단 바 삭제로 톱니바퀴
       버튼이 없어짐 — 이제 AI 비서에게 "설정 열어줘"라고 말해 새 탭으로
       여는 게 주 경로. 왼쪽 메뉴(left-menu.html)의 프로필·AI설정·GDC지갑
       등 sqa-* 바로가기가 백업 경로로 남아 있음. 이 스와이프들과는 분리됨. -->
<script>
(function () {
  const EDGE_ZONE   = 24;  // 가장자리 감지 폭(px) — 브라우저 기본 제스처와 같은 영역
  const OPEN_THRESH = 60;  // 패널을 열기로 확정하는 최소 이동 거리(px)
  const MOVE_DECIDE = 10;  // 의도한 축과 반대 축 스와이프를 구분하기 위한 최소 이동 거리(px)

  function anyOverlayOpen() {
    // settings-overlay: 설정/검색/진행상황/AI설정 시트 공유 클래스
    // ai-overlay: AI 비서 카드, left/right-menu-overlay: 좌/우 메뉴, manual-overlay: 사용자 매뉴얼
    return !!document.querySelector(
      '.settings-overlay.open, .ai-overlay.open, .left-menu-overlay.open, .right-menu-overlay.open, .manual-overlay.open, .pdv-overlay.open, .account-delete-overlay.open'
    );
  }

  // edge: 'left'|'right'|'top'. dir: 그 가장자리에서 유효한 스와이프 방향
  // (left/right는 +1=오른쪽,-1=왼쪽 / top은 +1=아래쪽만 사용)
  function setupEdgeSwipe(edge, dir, onOpen) {
    const axis = (edge === 'top') ? 'y' : 'x'; // top은 세로축, left/right는 가로축
    let startX = 0, startY = 0;
    let tracking = false, decided = false, intercepted = false;

    function inEdgeZone(x, y) {
      if (edge === 'left')  return x <= EDGE_ZONE;
      if (edge === 'right') return x >= window.innerWidth - EDGE_ZONE;
      /* top */             return y <= EDGE_ZONE;
    }

    function onTouchStart(e) {
      if (e.touches.length !== 1) return;
      const t = e.touches[0];
      if (!inEdgeZone(t.clientX, t.clientY)) return;
      if (anyOverlayOpen()) return;

      startX = t.clientX;
      startY = t.clientY;
      tracking = true;
      decided = false;
      intercepted = false;
    }

    function onTouchMove(e) {
      if (!tracking) return;
      const t  = e.touches[0];
      const dx = t.clientX - startX;
      const dy = t.clientY - startY;
      const primary = axis === 'x' ? dx : dy; // 이 엣지가 기대하는 축의 이동량
      const cross   = axis === 'x' ? dy : dx; // 반대 축 이동량(스크롤 등과 구분용)

      if (!decided) {
        if (Math.abs(dx) < MOVE_DECIDE && Math.abs(dy) < MOVE_DECIDE) return;
        decided = true;
        // 반대 축 움직임이 더 크거나, 이 가장자리에서 기대하는 방향이 아니면 우리 제스처가 아님
        const wrongDir = dir > 0 ? primary <= 0 : primary >= 0;
        if (Math.abs(cross) >= Math.abs(primary) || wrongDir) { tracking = false; return; }
        intercepted = true;
      }

      if (intercepted) {
        // 브라우저의 엣지 기본 제스처(뒤로가기/당겨서 새로고침)가 발동하기 전에 선점
        e.preventDefault();
      }
    }

    function onTouchEnd(e) {
      if (!tracking) return;
      tracking = false;
      if (!intercepted) return;

      const t = e.changedTouches[0];
      const moved = axis === 'x'
        ? Math.abs(t.clientX - startX)
        : Math.abs(t.clientY - startY);
      if (moved > OPEN_THRESH) onOpen();
    }

    function onTouchCancel() {
      tracking = false;
      intercepted = false;
    }

    document.addEventListener('touchstart',  onTouchStart,  { passive: true });
    document.addEventListener('touchmove',   onTouchMove,   { passive: false }); // preventDefault 위해 non-passive 필수
    document.addEventListener('touchend',    onTouchEnd,    { passive: true });
    document.addEventListener('touchcancel', onTouchCancel, { passive: true });
  }

  // BUG-FIX(2026-07-01): setupEdgeSwipe(..., openLeftMenu)처럼 함수를 직접
  // 넘기면, 이 시점의 openLeftMenu(아직 튜토리얼 래퍼가 씌워지기 전의 원본)가
  // 그대로 캡처된다. 이후 다른 스크립트 블록에서 window.openLeftMenu를
  // "_tutorialSignal 호출까지 포함한 버전"으로 감싸도, 스와이프 경로는 이미
  // 캡처해 둔 원본만 계속 호출하므로 튜토리얼 신호가 영원히 발동하지 않았다
  // — 가장자리를 "눌러서(클릭)" 열 때만 우연히 정상 동작했다(onclick 속성은
  // 호출 시점에 window.openLeftMenu를 새로 조회하기 때문). 화살표 함수로
  // 감싸 호출 시점에 매번 최신 window.openLeftMenu/openRightMenu를 조회하도록
  // 바꿔 스와이프로 열 때도 튜토리얼 신호가 정상 발동하게 한다.
  setupEdgeSwipe('left',  +1, () => window.openLeftMenu());    // 왼쪽 가장자리 → 오른쪽으로 스와이프
  setupEdgeSwipe('right', -1, () => window.openRightMenu());   // 오른쪽 가장자리 → 왼쪽으로 스와이프
  setupEdgeSwipe('top',   +1, openUserManual);  // 위쪽 가장자리 → 아래로 스와이프
})();

// ════════════════════════════════════════════════════════
// AI 비서 패널 — slide-up 반투명 패널
// ════════════════════════════════════════════════════════
(function() {
  const panel    = document.getElementById('ai-panel');
  const handle   = document.getElementById('ai-panel-handle');
  const msgList  = document.getElementById('ai-panel-messages');
  const input    = document.getElementById('ai-panel-input');
  const sendBtn  = document.getElementById('ai-panel-send');
  const btnAI    = document.getElementById('btn-ai');
  const attachBtn       = document.getElementById('ai-panel-attach-btn');
  const cameraBtn       = document.getElementById('ai-panel-camera-btn');
  const micBtn          = document.getElementById('ai-panel-mic-btn');
  const fileInput       = document.getElementById('ai-panel-file-input');
  const cameraInput     = document.getElementById('ai-panel-camera-input');
  const attachPreview   = document.getElementById('ai-panel-attach-preview');
  const attachNameEl    = document.getElementById('ai-panel-attach-name');
  const attachRemoveBtn = document.getElementById('ai-panel-attach-remove');
  let _panelOpen = false;
  // ── 응답 중단(stop) 기능 — 2026-07-07 신설 ──────────────
  // 전송 버튼이 생성 중에는 "중단" 버튼으로 바뀌고, 클릭 시 진행 중인
  // fetch를 AbortController로 취소한다. _callPanelAI 안에서 매 candidate
  // 시도마다 새 AbortController가 만들어지므로, 그 참조를 이 바깥 스코프
  // 변수에 최신 상태로 계속 갱신해 둔다.
  let _panelGenerating  = false;
  let _panelAbortCtl    = null;
  let _panelUserAborted = false;

  // ── PDV 누적량 → AI 버튼 색상 (2026-07-07 신설) ──────────────────
  // "데이터가 많을수록 AI가 사용자를 더 정확히 대신할 수 있다"는 것을
  // 색으로 보여준다. 연한 하늘색(#c9daf8)에서 시작해 기록이 쌓일수록
  // 짙은 청색(#1c4587)까지 6단계로 진해진다. 뒤 2단계는 배경이 어두워
  // 검정 글자 대비가 부족해지므로 글자색만 흰색으로 전환한다.
  const _AI_BTN_TIERS = [
    { min: 0,   bg: '#c9daf8', fg: '#000' },
    { min: 1,   bg: '#a4c2f4', fg: '#000' },
    { min: 5,   bg: '#6d9eeb', fg: '#000' },
    { min: 15,  bg: '#3c78d8', fg: '#fff' },
    { min: 40,  bg: '#1155cc', fg: '#fff' },
    { min: 100, bg: '#1c4587', fg: '#fff' },
  ];
  function _aiButtonTierFor(count) {
    let tier = _AI_BTN_TIERS[0];
    for (const t of _AI_BTN_TIERS) { if (count >= t.min) tier = t; }
    return tier;
  }
  async function _updateAIButtonPdvColor() {
    try {
      if (!window.GopangPDV?.list) return; // pdv-store.js 아직 로드 전이면 스킵(다음 이벤트 때 재시도)
      const records = await window.GopangPDV.list();
      const count = records.length;
      const tier = _aiButtonTierFor(count);
      btnAI.style.setProperty('--ai-btn-bg', tier.bg);
      btnAI.style.setProperty('--ai-btn-fg', tier.fg);
      btnAI.title = `기록 ${count}건 — 데이터가 쌓일수록 AI 비서가 회원님을 더 정확히 대신할 수 있어요.`;
    } catch (e) {
      console.warn('[AI버튼] PDV 색상 갱신 실패:', e.message);
    }
  }
  _updateAIButtonPdvColor();
  // 새 PDV 기록이 쌓일 때마다(대화 종료, 거래 등) 즉시 재계산
  window.addEventListener('gopang:pdv-recorded', _updateAIButtonPdvColor);


  // ── 열기 / 닫기 ──────────────────────────────────────
  const triggerBtn = document.getElementById('ai-panel-trigger');

  let _panelGreeted = false; // 패널 첫 인사 여부

  // edge-handle 요소 캐시 (BUG-7)
  const _edgeHandles = document.querySelectorAll('.edge-handle, .edge-handle-top');

  function openAIPanel() {
    if (_panelOpen) return;  // 이미 열림 — 토글로 닫히지 않음

    _panelOpen = true;
    panel.classList.add('open');
    btnAI.classList.add('panel-open');
    // BUG-7: AI 패널(z-index:300) 위로 edge-handle이 표시되도록 z-index 상향
    _edgeHandles.forEach(el => el.style.zIndex = '400');
    // focus() 자동 호출 제거 — 사용자가 직접 탭해야만 키패드 열림

    // 온보딩 메시지가 대기 중이면 AI 패널에서 자동 시작 (1회)
    if (window._aiPanelOnboardingMsg) {
      const msg = window._aiPanelOnboardingMsg;
      delete window._aiPanelOnboardingMsg;
      setTimeout(async () => {
        const aiBubble = _appendPanelMsg('ai', '…');
        aiBubble.classList.add('streaming');
        try { await _callPanelAI(msg, aiBubble); }
        catch(e) { aiBubble.textContent = 'AI 오류: ' + e.message; }
        aiBubble.classList.remove('streaming');
      }, 400);
    } else if (!_panelGreeted && msgList.children.length === 0) {
      // ★ BUG-FIX(2026-07-11): closeAIPanel()은 화면만 지우고 _panelHistory는
      // 의도적으로 유지하는데(아래 closeAIPanel 주석 참조), 이 분기는
      // "화면이 비어 있으면 = 처음 여는 것"으로만 판단해서 매번
      // [INTERNAL: 패널이 열렸습니다...] 트리거를 다시 보내고 있었다.
      // 그 결과 사용자가 패널을 닫았다 열기만 반복해도(실제 발화 없이)
      // _panelHistory(최근 20개 캡)가 의미 없는 인사 왕복으로 계속
      // 채워지고, 한 번이라도 깨진 응답(예: {ASSISTANT_NAME} 미치환)이
      // 끼어들면 모델이 자기 과거 발화에 anchoring되어 그 패턴을 계속
      // 반복 재생하는 사고가 실사로 확인됐다. "새 대화 시작 시 이전 맥락을
      // 참고해 자연스럽게 이어서 인사한다"는 원래 설계 의도(§0-1-P 3번
      // 원칙)는 유지하되, 직전에 이미 같은 인사 트리거만 있고 그 사이
      // 사용자의 실제 발화가 없었다면 트리거를 또 보내지 않는다.
      const _lastUserMsg = [..._panelHistory].reverse().find(m => m.role === 'user');
      const _lastWasGreetTrigger = _lastUserMsg && typeof _lastUserMsg.content === 'string'
        && _lastUserMsg.content.startsWith('[INTERNAL: 패널이 열렸습니다');
      if (_lastWasGreetTrigger) {
        // 새 LLM 호출·새 히스토리 항목 없이, 마지막으로 실제 생성됐던
        // AI 응답을 화면에만 조용히 복원한다(히스토리 오염 방지).
        _panelGreeted = true;
        const _lastAiMsg = [..._panelHistory].reverse().find(m => m.role === 'assistant');
        if (_lastAiMsg && typeof _lastAiMsg.content === 'string') {
          import('./src/gopang/ai/call-ai.js').then(mod => {
            const strip = typeof mod._stripInternalTags === 'function' ? mod._stripInternalTags : (s => s);
            _appendPanelMsg('ai', strip(_lastAiMsg.content));
          }).catch(() => { _appendPanelMsg('ai', _lastAiMsg.content); });
        }
        return;
      }
      // BUG-FIX(2026-07-02): nickname이 아직 비어 있는 상태(가입 직후
      // localStorage 반영 전/guest·temp 상태 등)에서 첫 인사가 트리거되면
      // "****님"처럼 닉네임이 빈 문자열로 치환된 응답이 그대로 LLM에 의해
      // 생성되고, _savePanelHistory()가 그 완성된 문자열을 그대로
      // hondi_panel_history_v1에 저장한다. 이후 hondi_first_greeted='1'로
      // 고정되고 히스토리는 재생성 없이 그대로 재렌더링되므로, 한번 비어
      // 있으면 사용자가 콘솔로 직접 초기화하기 전까진 영구히 고정된다.
      //
      // BUG-FIX(2026-07-02, 2차): 위 1차 수정은 nickname이 없으면 그냥
      // return해서 "다음 openAIPanel() 호출 때 재시도"하도록 미뤘는데,
      // 문제는 웹앱이 가입 직후 openAIPanel()을 "고정 300ms" 뒤 자동
      // 1회만 호출한다는 점이다(아래 "기본 활성화" 블록). 반면
      // auth.js의 _completeRegistration()은 L1 프로필 생성 fetch를
      // await한 "뒤"에야 localStorage.setItem('gopang_user_v4', ...)를
      // 실행한다 — 모바일 네트워크·Worker 콜드스타트 등으로 이 fetch가
      // 300ms를 넘기면, 자동 오픈 시점엔 nickname이 아직 없어 조기
      // 리턴하고, 사용자가 패널을 수동으로 다시 열기 전까진 인사말이
      // 영원히 나타나지 않는다(사용자 입장에선 "환영 멘트가 없다").
      // → 조기 포기 대신 짧은 간격으로 폴링 재시도하고, 그래도 끝내
      //   준비 안 되면 닉네임 없이라도 인사는 반드시 띄운다(무한 침묵 방지).
      const _tryGreet = (retriesLeft) => {
        const _greetUser = (() => {
          try {
            return JSON.parse(
              localStorage.getItem('gopang_user_v4') ||
              sessionStorage.getItem('gopang_user_v4') || '{}'
            );
          } catch { return {}; }
        })();
        if (!_greetUser.nickname && retriesLeft > 0) {
          setTimeout(() => _tryGreet(retriesLeft - 1), 400);
          return;
        }
        if (!_greetUser.nickname) {
          console.warn('[Panel] nickname 끝내 미준비 — 닉네임 없이 인사 진행');
        }
        // 첫 실행 시 AI가 먼저 말을 건다. v1.6 — 이제 항상 AGENT-COMMON이
        // 응답한다. 최초 인사("이름을 지어주세요" + 프로필 작성 안내)는
        // PA SP가 아니라 _callPanelAI 안의 _buildFirstContactContext()가
        // first_greeted=false일 때만 1회성 컨텍스트로 끼워 넣어 처리한다
        // (call-ai.js 참조) — SP 본문에는 영구히 남지 않는다.
        _panelGreeted = true;
        (async () => {
          const user = (() => { try { return JSON.parse(localStorage.getItem('gopang_user_v4') || sessionStorage.getItem('gopang_user_v4') || '{}'); } catch { return {}; } })();
          const nickname = user.nickname || '';
          const aiBubble = _appendPanelMsg('ai', '…');
          aiBubble.classList.add('streaming');
          // ★ 2026-07-11 수정: 튜토리얼 대본이 AC에서 profile-assistant로
          // 이관됐다(§0-1-T 삭제, PHASE -1 신설) — 그래서 이 트리거가
          // AC에게 "튜토리얼을 진행해 주세요"라고 직접 지시하면 안 된다
          // (AC는 더 이상 그 대본을 갖고 있지 않다). 첫 방문(firstGreeted
          // 미완료)이면 call-ai.js의 _buildFirstContactContext()가 붙이는
          // [FIRST_CONTACT] 블록이 인사를 전담하고, 그 인사의 마지막
          // 질문("준비되셨나요?")에 사용자가 답하면 AC 자신의 지침(§0-1)에
          // 따라 [CALL_PROFILE_ASSISTANT]로 넘어가 PA가 튜토리얼을
          // 시작한다 — 그래서 이 경우엔 트리거를 중립적으로만 보낸다.
          // 반면 이미 인사는 마쳤는데 튜토리얼을 중간에 그만둔 재방문자
          // (firstGreeted=true, tutDone=false)에게는 AC가 재인사 후
          // "이어서 하시겠어요?"라고 자연스럽게 물어보고 동의 시 같은
          // 방식으로 넘기도록 별도로 알려준다.
          const _tutDone = (() => { try { return localStorage.getItem('hondi_tutorial_done') === '1'; } catch { return false; } })();
          const _firstGreetedFlag = (() => { try { return localStorage.getItem('hondi_first_greeted') === '1'; } catch { return false; } })();
          const _greetMsg = _tutDone
            ? '[INTERNAL: 패널이 열렸습니다. 먼저 인사해 주세요.]'
            : (_firstGreetedFlag
                ? '[INTERNAL: 패널이 열렸습니다. 이전에 시작한 앱 사용법 ' +
                  '튜토리얼이 아직 끝나지 않았습니다. 자연스럽게 인사한 뒤, ' +
